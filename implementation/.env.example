# Base de données PostgreSQL (Vercel Postgres)
# Rempli automatiquement si tu utilises "Vercel Postgres" depuis le dashboard Vercel
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# Secret NextAuth — générer avec : openssl rand -base64 32
AUTH_SECRET=""

# URL de l'app (automatiquement défini par Vercel en prod)
NEXTAUTH_URL="http://localhost:3000"
